# CEX Service — Environment Variables Template
#
# Copy this file to .env (gitignored) and fill in actual values
# For production: use Secrets Manager, NOT this file
#
# IMPORTANT: NEVER commit .env to git

# ============================================
# Application
# ============================================
APP_NAME=my-service
APP_ENV=development                 # development | staging | production
APP_PORT=8080
LOG_LEVEL=info                      # debug | info | warn | error

# ============================================
# Database
# ============================================
# Aurora MySQL (production: dùng IRSA + IAM DB Auth Token, không password)
DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/dbname
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=5000

# ============================================
# Cache
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_TLS_ENABLED=false

# ============================================
# Authentication
# ============================================
# Use Secrets Manager in production — NOT this file
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ISSUER=your-service.example
JWT_AUDIENCE=your-service-api
JWT_ACCESS_TOKEN_TTL_MIN=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ============================================
# External Services (placeholder — use Secrets Manager in prod)
# ============================================
AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY: prefer IAM Role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================
# Feature Flags
# ============================================
FEATURE_NEW_WITHDRAWAL_FLOW=false
FEATURE_BIOMETRIC_AUTH=false
